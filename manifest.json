{
  "manifest_version": 3,
  "name": "Flying Lyrics - Romanize Your Lyrics",
  "short_name": "FlyingLyrics",
  "version": "4.5",
  "description": "A floating extension for synchronized lyrics, romanization, and translations to sing along while multitasking.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "icons": {
    "16": "assets/icons/icon.png",
    "32": "assets/icons/icon.png",
    "48": "assets/icons/icon.png",
    "128": "assets/icons/icon.png"
  },
  "host_permissions": [
    "https://lrclib.net/*",
    "https://translate.googleapis.com/*",
    "https://i.scdn.co/*",
    "https://music.163.com/*",
    "https://*.spotifycdn.com/*",
    "https://www.google-analytics.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://open.spotify.com/*",
        "*://music.youtube.com/*"
      ],
      "js": [
        "src/content/mainWorldHook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://open.spotify.com/*",
        "*://music.youtube.com/*"
      ],
      "js": [
        "src/background/storage.js",
        "src/content/config.js",
        "src/content/content.js",
        "src/content/selectors.js",
        "src/content/utils.js",
        "src/content/services.js",
        "src/content/ui.js",
        "src/content/pipDrivers.js",
        "src/content/renderer.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon.png",
      "32": "assets/icons/icon.png",
      "48": "assets/icons/icon.png",
      "128": "assets/icons/icon.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/styles.css",
        "src/content/inject.js",
        "src/pages/update.html",
        "src/pages/update.js",
        "assets/icons/icon.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}